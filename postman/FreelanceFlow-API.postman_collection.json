{
  "info": {
    "name": "FreelanceFlow API",
    "description": "FreelanceFlow — NestJS backend for French-market freelance invoicing.\n\n**Base URL:** `{{baseUrl}}`  (default: http://localhost:3001/api/v1)\n\n**Auth flow:**\n1. Run **Auth / Register** or **Auth / Login** — the `accessToken` collection variable is set automatically.\n2. All protected requests use that token via the collection-level Bearer auth.\n\n**Chained IDs:** Creating a Client, Service, or Invoice automatically stores its `id` in `clientId`, `serviceId`, or `invoiceId` collection variables for use in subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "serviceId", "value": "", "type": "string" },
    { "key": "invoiceId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('accessToken saved from register');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sophie@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('accessToken saved from login');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sophie@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Uses the HttpOnly `refreshToken` cookie set by Login. Postman sends cookies automatically when the setting is enabled."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', '');",
                  "  console.log('accessToken cleared');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Sophie Martin\",\n  \"legalName\": \"Sophie Marie Martin\",\n  \"companyName\": \"SophieDev SARL\",\n  \"addressLine1\": \"123 rue de la Paix\",\n  \"addressLine2\": \"Appartement 4B\",\n  \"postalCode\": \"75001\",\n  \"city\": \"Paris\",\n  \"country\": \"FR\",\n  \"vatNumber\": \"FR12345678901\",\n  \"siret\": \"12345678901234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Create client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('clientId', json.id);",
                  "  console.log('clientId saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sophie Martin\",\n  \"email\": \"sophie@acme.fr\",\n  \"company\": \"Acme SAS\",\n  \"address\": \"42 rue du Commerce, 75015 Paris\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/clients", "host": ["{{baseUrl}}"], "path": ["clients"] }
          }
        },
        {
          "name": "List clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/clients", "host": ["{{baseUrl}}"], "path": ["clients"] }
          }
        },
        {
          "name": "Get client",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientId}}"]
            }
          }
        },
        {
          "name": "Update client",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sophie Martin (updated)\",\n  \"email\": \"sophie.updated@acme.fr\",\n  \"company\": \"Acme SAS\",\n  \"address\": \"10 avenue Victor Hugo, 75016 Paris\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientId}}"]
            }
          }
        },
        {
          "name": "Delete client",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "{{clientId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Services (Prestations)",
      "item": [
        {
          "name": "Create service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('serviceId', json.id);",
                  "  console.log('serviceId saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Développement backend\",\n  \"hourlyRateHt\": 150.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] }
          }
        },
        {
          "name": "List services",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] }
          }
        },
        {
          "name": "Get service",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        },
        {
          "name": "Update service",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Développement backend senior\",\n  \"hourlyRateHt\": 175.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        },
        {
          "name": "Delete service",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["services", "{{serviceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Invoices (Factures)",
      "item": [
        {
          "name": "Create invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('invoiceId', json.id);",
                  "  console.log('invoiceId saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"issueDate\": \"2026-04-11\",\n  \"dueDate\": \"2026-05-11\",\n  \"currency\": \"EUR\",\n  \"lines\": [\n    {\n      \"lineOrder\": 1,\n      \"description\": \"Développement backend — sprint 1\",\n      \"quantity\": 10,\n      \"unitPriceHt\": 150.00,\n      \"vatRate\": 0.20\n    },\n    {\n      \"serviceId\": \"{{serviceId}}\",\n      \"lineOrder\": 2,\n      \"description\": \"Conseil architecture\",\n      \"quantity\": 2,\n      \"unitPriceHt\": 150.00,\n      \"vatRate\": 0.20\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/invoices", "host": ["{{baseUrl}}"], "path": ["invoices"] },
            "description": "Line 2 uses `serviceId` — the unit price is overridden by the service snapshot rate."
          }
        },
        {
          "name": "List invoices",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/invoices", "host": ["{{baseUrl}}"], "path": ["invoices"] }
          }
        },
        {
          "name": "Get invoice",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}"]
            }
          }
        },
        {
          "name": "Update invoice metadata (draft only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issueDate\": \"2026-04-12\",\n  \"dueDate\": \"2026-05-12\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}"]
            }
          }
        },
        {
          "name": "Replace invoice lines (draft only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lines\": [\n    {\n      \"lineOrder\": 1,\n      \"description\": \"Développement backend — sprint 2 (updated)\",\n      \"quantity\": 15,\n      \"unitPriceHt\": 150.00,\n      \"vatRate\": 0.20\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/lines",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}", "lines"]
            },
            "description": "Replaces ALL existing lines atomically. Totals are recalculated."
          }
        },
        {
          "name": "Send invoice (draft → sent)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"sent\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}", "status"]
            },
            "description": "State machine: draft → sent | cancelled   /   sent → paid | cancelled"
          }
        },
        {
          "name": "Mark invoice paid (sent → paid)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"paid\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}", "status"]
            }
          }
        },
        {
          "name": "Cancel invoice",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}", "status"]
            }
          }
        },
        {
          "name": "Delete invoice (draft or cancelled only)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "PDF",
      "item": [
        {
          "name": "Download invoice PDF",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pdf/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["pdf", "invoices", "{{invoiceId}}"]
            },
            "description": "Returns `application/pdf`. In Postman, click **Send and Download** to save the file."
          }
        }
      ]
    }
  ]
}

# FreelanceFlow API Environment Variables

# Application
PORT=3001
NODE_ENV=development

# Build-time identity (set in Docker/CI; optional locally — see GET /api/v1/health)
# GIT_SHA=local

# Neon Database - Replace with your actual Neon connection string
DATABASE_URL="postgresql://neondb_owner:your_password@your-endpoint.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT Configuration - Generate a secure 64-byte hex secret
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_64_byte_hex_jwt_secret_here_generate_new_one_for_production
JWT_EXPIRES_IN=1d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (for sessions/caching - optional)
REDIS_URL=redis://localhost:6379

# Email (for future notifications - optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Elasticsearch (optional) — ECS JSON logs are bulk-indexed while stdout stays JSON (prod) or pretty (dev).
# When enabled, the process also formats stdout with ECS (same NDJSON as shipped to ES).
# ELASTICSEARCH_URL=https://my-deployment.es.region.cloud.es.io
# ELASTICSEARCH_API_KEY=base64ApiKeyId:WkxiOGtwMEIzUzJ2WmIybzBtUHg6RDctUEZ5akcxS0F4alNFVWNUU2k5Zw==  (Elastic Cloud API key; preferred)
# Or basic auth:
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=secret
# ELASTICSEARCH_LOG_INDEX=freelanceflow-api-logs
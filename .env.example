# FreelanceFlow API Environment Variables

# Application
PORT=3001
NODE_ENV=development

# Neon Database - Replace with your actual Neon connection string
DATABASE_URL="postgresql://neondb_owner:your_password@your-endpoint.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT Configuration - Generate a secure 64-byte hex secret
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_64_byte_hex_jwt_secret_here_generate_new_one_for_production
JWT_EXPIRES_IN=1d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (for sessions/caching - optional)
REDIS_URL=redis://localhost:6379

# Email (for future notifications - optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=